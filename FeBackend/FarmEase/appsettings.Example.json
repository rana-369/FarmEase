{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FarmEaseDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "JWT": {
    "ValidAudience": "http://localhost:5173",
    "ValidIssuer": "https://localhost:7284",
    "Secret": "YOUR_JWT_SECRET_KEY_HERE_MIN_32_CHARS"
  },

  "Razorpay": {
    "Key": "YOUR_RAZORPAY_KEY_ID",
    "Secret": "YOUR_RAZORPAY_KEY_SECRET",
    "WebhookSecret": "YOUR_WEBHOOK_SECRET"
  },

  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Email": "your-email@gmail.com",
    "Password": "your-app-password-here",
    "EnableSsl": "true"
  }
}
